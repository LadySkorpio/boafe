---
---
<section class="newsletter">
  <div class="container newsletter-inner">
    <h2>Receba <span>dicas e notícias</span> no seu email.</h2>
    <div>
      <form class="newsletter-form" action="https://formsubmit.co/me@hellen.design" method="POST">
        <input type="email" name="email" placeholder="seu@email.com" autocomplete="email" required />
        <input type="hidden" name="_subject" value="Nova inscrição na newsletter — BOAFÉ" />
        <input type="hidden" name="_template" value="table" />
        <input type="hidden" name="_captcha" value="false" />
        <input type="hidden" name="_next" value="/obrigado" />
        <input type="text" name="_honey" style="display:none" tabindex="-1" autocomplete="off" />
        <button type="submit">Assinar →</button>
      </form>
      <p class="newsletter-note">Sem spam. Sem calote. Cancele quando quiser.</p>
    </div>
  </div>
</section>
